# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GROQ AI ───────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_...

# ─── RESEND (email) ────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=TransitOps <noreply@yourdomain.com>

# ─── APP ───────────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production (e.g. https://transitops.vercel.app)
# Used for absolute URL redirects (Supabase auth callbacks, email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── ADMIN SEED ────────────────────────────────────────────────────────────────
# Only needed when running the seed script — not required at runtime
ADMIN_EMAIL=admin@transitops.com
